-- =================== ФУНКЦИИ ДУПА ===================
local function getClosestItem(maxDist)
    local closest = nil
    local closestDist = maxDist or 40
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local itemsFolder = workspace:FindFirstChild("Items")
    if not itemsFolder then return nil end

    for _, item in pairs(itemsFolder:GetChildren()) do
        if item:IsA("Model") and item.PrimaryPart then
            local dist = (hrp.Position - item.PrimaryPart.Position).Magnitude
            if dist < closestDist then closest = item; closestDist = dist end
        elseif item:IsA("BasePart") then
            local dist = (hrp.Position - item.Position).Magnitude
            if dist < closestDist then closest = item; closestDist = dist end
        end
    end
    return closest
end

local function refreshBackpackList()
    backpackItems = {}
    for _, item in pairs(Backpack:GetChildren()) do
        if item:IsA("Tool") then table.insert(backpackItems, item.Name) end
    end
    if #backpackItems == 0 then table.insert(backpackItems, "empty") end
    return backpackItems
end

local function findItemModel(itemName)
    local playerFolder = workspace:FindFirstChild("player")
    if playerFolder then
        local model = playerFolder:FindFirstChild(itemName)
        if model and model:IsA("Model") then return model end
    end
    local playerModel = workspace:FindFirstChild(LocalPlayer.Name)
    if playerModel then
        local model = playerModel:FindFirstChild(itemName)
        if model and model:IsA("Model") then return model end
    end
    local character = LocalPlayer.Character
    if character then
        for _, obj in pairs(character:GetChildren()) do
            if obj:IsA("Model") and obj.Name == itemName then return obj end
        end
    end
    return nil
end

local function findWeaponModel()
    local character = LocalPlayer.Character
    if not character then return nil end
    for _, obj in pairs(character:GetDescendants()) do
        if obj:IsA("Model") and obj.Name == "Weapon" then return obj end
    end
    return nil
end

local function startAutoPickup()
    pickupEnabled = true
    task.spawn(function()
        while pickupEnabled do
            local closestItem = getClosestItem(pickupDistance)
            if closestItem then
                local args = { [1] = "Pickup", [2] = closestItem }
                pcall(function()
                    ReplicatedStorage.Inventory:FireServer(unpack(args))
                end)
            end
            task.wait(pickupDelay)
        end
    end)
end

local function stopAutoPickup()
    pickupEnabled = false
end

local function doDupe(itemName, times, pickups)
    local itemsFolder = workspace:FindFirstChild("Items")
    if not itemsFolder then
        itemsFolder = Instance.new("Folder")
        itemsFolder.Name = "Items"
        itemsFolder.Parent = workspace
    end

    local totalPickups = times * pickups
    local successfulPickups = 0

    startAutoPickup()
    task.wait(0.5)

    for i = 1, times do
        Rayfield:Notify({ Title = "Dupe GUI", Content = "Cycle " .. i .. "/" .. times, Duration = 2 })
        local tool = Backpack:FindFirstChild(itemName)
        if not tool then
            stopAutoPickup()
            Rayfield:Notify({ Title = "Error", Content = "Tool '" .. itemName .. "' not found!", Duration = 3 })
            return
        end

        local character = LocalPlayer.Character
        if not character then 
            stopAutoPickup()
            return 
        end
        local humanoid = character:FindFirstChildOfClass("Humanoid")
        if humanoid then humanoid:EquipTool(tool) end
        task.wait(0.3)

        local equippedTool = character:FindFirstChildOfClass("Tool")
        if equippedTool then equippedTool.Parent = Backpack end
        task.wait(0.3)

        local itemModel = findItemModel(itemName)
        if itemModel then itemModel.Parent = itemsFolder; task.wait(0.2) end
        local weaponModel = findWeaponModel()
        if weaponModel then weaponModel.Parent = itemsFolder; task.wait(0.2) end
        task.wait(0.3)

        for p = 1, pickups do
            task.wait(0.5)
        end
        
        successfulPickups = successfulPickups + pickups
        task.wait(0.5)
    end

    stopAutoPickup()
    task.wait(1)

    Rayfield:Notify({ Title = "Dupe GUI", Content = "Sending to Vault...", Duration = 3 })
    local vaultSuccess = 0
    for i = 1, totalPickups do
        local safeItems = LocalPlayer:FindFirstChild("SafeItems")
        if safeItems then
            local vaultItem = safeItems:FindFirstChild(itemName)
            if vaultItem then
                ReplicatedStorage:WaitForChild("Vault"):FireServer("Vault", vaultItem)
                vaultSuccess = vaultSuccess + 1
                task.wait(0.2)
            end
        end
    end
    Rayfield:Notify({ Title = "Complete!", Content = "Pickup: " .. successfulPickups .. " | Vault: " .. vaultSuccess, Duration = 4 })
end

-- =================== ФУНКЦИИ INFINITE BRICKS ===================
local function doInfiniteBricks(count)
    local itemName = brickName
    
    Rayfield:Notify({ Title = "Infinite Bricks", Content = "Sending " .. count .. " packets...", Duration = 2 })
    
    task.spawn(function()
        -- Проверяем наличие предмета
        local item = Backpack:FindFirstChild(itemName) 
            or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(itemName))
        
        if not item then
            Rayfield:Notify({ Title = "Error", Content = itemName .. " not found!", Duration = 3 })
            return
        end
        
        -- Сохраняем камеру
        local savedCFrame = workspace.CurrentCamera.CFrame
        local remote = ReplicatedStorage:FindFirstChild("UseItem")
        
        if not remote then
            Rayfield:Notify({ Title = "Error", Content = "UseItem remote not found!", Duration = 3 })
            return
        end
        
        -- СПАМ БЕЗ ПОТЕРИ
        for i = 1, count do
            task.spawn(function()
                pcall(function()
                    remote:FireServer(item, savedCFrame)
                end)
            end)
        end
        
        task.wait(0.5)
        Rayfield:Notify({ Title = "Done", Content = "Sent " .. count .. " packets!", Duration = 2 })
    end)
end

-- =================== ФУНКЦИИ ДРОПЕРА ===================
local function getPlayersList()
    local playerNames = {}
    for _, plr in pairs(Players:GetPlayers()) do
        table.insert(playerNames, plr.Name)
    end
    if #playerNames == 0 then table.insert(playerNames, "no players") end
    return playerNames
end

local function getPlayerItems(plr)
    itemMap = {}
    local itemNames = {"select item..."}
    if not plr then return itemNames end
    
    local backpack = plr:FindFirstChild("Backpack")
    local character = plr.Character
    local count = {}
    
    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                count[item.Name] = (count[item.Name] or 0) + 1
                local displayName = item.Name .. " [#" .. count[item.Name] .. "]"
                table.insert(itemNames, displayName)
                itemMap[displayName] = item
            end
        end
    end
    
    if character then
        for _, item in pairs(character:GetChildren()) do
            if item:IsA("Tool") then
                count[item.Name] = (count[item.Name] or 0) + 1
                local displayName = item.Name .. " [hand #" .. count[item.Name] .. "]"
                table.insert(itemNames, displayName)
                itemMap[displayName] = item
            end
        end
    end
    
    if #itemNames == 1 then table.insert(itemNames, "empty") end
    return itemNames
end

local function getVaultItems(plr)
    vaultMap = {}
    local itemNames = {"select item..."}
    if not plr then return itemNames end
    
    local safeItems = plr:FindFirstChild("SafeItems")
    local count = {}
    
    if safeItems then
        for _, item in pairs(safeItems:GetChildren()) do
            count[item.Name] = (count[item.Name] or 0) + 1
            local displayName = item.Name .. " [#" .. count[item.Name] .. "]"
            table.insert(itemNames, displayName)
            vaultMap[displayName] = item
        end
    end
    
    if #itemNames == 1 then table.insert(itemNames, "empty") end
    return itemNames
end

local function updateItemDropdown()
    if selectedPlayer and ItemDropdown2 then
        local itemNames = getPlayerItems(selectedPlayer)
        ItemDropdown2:Refresh(itemNames, true)
        pcall(function() ItemDropdown2:Set("select item...") end)
        selectedDropItem = nil
    end
end

local function updateVaultDropdown()
    if selectedPlayer and VaultDropdown then
        local itemNames = getVaultItems(selectedPlayer)
        VaultDropdown:Refresh(itemNames, true)
        pcall(function() VaultDropdown:Set("select item...") end)
        selectedDropItem = nil
    end
end

local function updateBackpackDropdown()
    if ItemDropdown then
        local list = refreshBackpackList()
        ItemDropdown:Refresh(list, true)
    end
end

local function updatePlayerDropdown()
    if PlayerDropdown then
        PlayerDropdown:Refresh(getPlayersList(), true)
    end
end

